{
  "expo": {
    "name": "AtendePro",
    "slug": "atendepro-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#f8fafc"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#f8fafc"
      }
    },
    "ios": {
      "supportsTablet": true
    },
    "plugins": [
      "expo-router",
      "expo-asset"
    ],
    "scheme": "atendepro",
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
